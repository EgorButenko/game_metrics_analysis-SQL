-- Допустим, “лояльным” считается пользователь, который входит в топ-100 пользователей по средним выплатам за один месяц своей жизни.

-- Список таких клиентов:

with ltr as
(select id_user
		, sum(cnt_buy*price)
from skygame.monetary as t1	
	join skygame.log_prices as t2
		on t1.id_item_buy = t2.id_item
		and dtime_pay >= valid_from 
		and dtime_pay <= coalesce(valid_to, '3000-01-01')
group by id_user
),

lt_month as 
(select t1.id_user
		, ceil(extract('days' from max(start_session) - min(reg_date)) / 30) as lt
from skygame.game_sessions as t1
	join skygame.users as t2
		on t1.id_user = t2.id_user
group by t1.id_user 
)

select lt.id_user
		, lt 
		, sum/lt as ltr_month
		, sum
from ltr 
	join lt_month as lt 
		on ltr.id_user = lt.id_user
order by ltr_month desc
limit 100
	

 
