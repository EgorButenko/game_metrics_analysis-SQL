-- K-factor нашей игры.

-- Сколько пользователей нам принесет одна будущая среднестатистическая когорта в результате.


with ref as 
(select  sum(case when ref_reg = '1' then 1.0 else 0.0 end) / count(distinct us.id_user) as k_factor
from skygame.users as us
	left join skygame.referral as r 
		on us.id_user = r.id_user
),
month as
(select date_trunc('month', reg_date) as mm
from skygame.users
group by mm
)

select round(count(distinct id_user)/ (select count(*) from month) * (select * from ref)) as users_per_cohort
from skygame.users




-- Рассчитать LMAU, LDAU, LWAU (Loyal MAU/DAU/WAU). Для того, чтобы произвести этот расчет необходимо определиться - какого пользователя мы считаем “лояльным”?

-- Допустим, “лояльным” считается тот пользователь, который пригласил как минимум троих друзей, из которых как минимум один в результате зарегистрировался в нашей игре.

-- Назовем данный критерий crit_invite.

-- Динамика LMAU для критерия лояльности crit_invite.


with crit_invites as 
(select id_user
		, count(*) as cnt_invite
		, sum(ref_reg) as cnt_reg
from skygame.referral
group by id_user
having count(*) >= 3
	and sum(ref_reg) >= 1
)

select date_trunc('month', start_session) as month
		, count(distinct id_user) as cnt_user
from skygame.game_sessions
where id_user in(select id_user from crit_invites)
group by month


-- Допустим, “лояльным” считается тот пользователь, который оплатил суммарно больше 1000 рублей за всё время (не строго).

-- Назовем данный критерий crit_1000.

-- Динамика LMAU для критерия лояльности crit_1000.

with crit_1000 as
(select id_user
		, sum(cnt_buy*price)
from skygame.monetary as t1	
	join skygame.log_prices as t2
		on t1.id_item_buy = t2.id_item
		and dtime_pay >= valid_from 
		and dtime_pay <= coalesce(valid_to, '3000-01-01')
group by id_user
having sum(cnt_buy*price) > 1000
)

select date_trunc('month', start_session) as mm
		, count(distinct id_user) as cnt_user
from skygame.game_sessions
where id_user in (select id_user from crit_1000)
group by mm



