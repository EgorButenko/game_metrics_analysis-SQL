-- Бонусы получат игроки, которые проводят в игре больше всего времени. Но в первую очередь нас интересуют игроки, зарегистрированные в 2022 году.

select us.id_user 
		, sum(extract(epoch from (end_session - start_session)))/(60*60) as game_time_hour
from skygame.users as us
	join skygame.game_sessions	as gs
		on us.id_user = gs.id_user
	where reg_date between '2022-01-01' and '2022-12-31'
	and end_session is not null
