-- Факт: В ноябре и декабре 2022 года была опробована альтернативная стратегия привлечения клиентов.

-- Гипотеза: в ноябре и декабре 2022 года из-за более дорогой и таргетированной рекламы мы приобрели более “лояльных” игроков, которые больше времени посвящают нашей игре.




with cohort as
(select id_user
from skygame.users
where reg_date between '2022-11-01' and '2022-12-31'
)

select case when us.id_user in (select * from cohort) then 'cohort 11-12.2022' else 'other cohort' end as cohort
		, avg(end_session - start_session) as avg_game_session
from skygame.users as us 
	left join skygame.game_sessions as gs 
		on us.id_user = gs.id_user
where end_session - start_session > interval '5 minute'
group by cohort


