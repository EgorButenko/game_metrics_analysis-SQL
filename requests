-- Объединение трех запросов в один

select 	  count(*) as cnt_sessions
		, sum(case when end_session is null then 1 else 0 end) as cnt_sessions_wrong
		, sum(case when end_session is null then 1.0 else 0.0 end)/count(*) as count_signif
		, sum(case when end_session is null and dev_type = 'ios' then 1.0 else 0.0 end)/sum(case when dev_type = 'ios' then 1.0 else 0.0 end) as problem_part_ios 
		, sum(case when end_session is null and dev_type = 'android' then 1.0 else 0.0 end)/sum(case when dev_type = 'android' then 1.0 else 0.0 end) as problem_part_android 
		, sum(case when end_session is null and dev_type = 'ios' then 1.0 else 0.0 end)/sum(case when end_session is null then 1 else 0 end) * 100 as problem_part_ios_percent
		, sum(case when end_session is null and dev_type = 'android' then 1.0 else 0.0 end)/sum(case when end_session is null then 1 else 0 end) * 100 as problem_part_android_percent
from skygame.users as us
	inner join skygame.game_sessions	as gs
		on us.id_user = gs.id_user



-- Динамика суммарных клиентских выплат по месяцам в разрезе по типам продукта.


select *
from skygame.monetary

select *
from skygame.item_list

select *
	, coalesce(valid_to, to_date('3000-01-01', 'YYYY-MM-DD')) as n_valid_to
from skygame.log_prices

select date_trunc('month', dtime_pay) as month
		, type
		, sum(cnt_buy*price) as revenue
from skygame.monetary as m
	join skygame.item_list as i
		on m.id_item_buy = i.id_item
	join skygame.log_prices as lp 
		on m.id_item_buy = lp.id_item
		and dtime_pay::date >= valid_from
		and dtime_pay::date < coalesce(valid_to, to_date('3000-01-01', 'YYYY-MM-DD'))
group by month , type	
order by type, month


