-- суммарное количества сессий дольше 5 минут,
select date_trunc ('month',start_session) as month_session
		, sum(case when end_session - start_session > interval '5 minute' then 1 else 0 end) as count_signif
from skygame.game_sessions
group by month_session
order by month_session
-- доли сессий дольше 5 минут среди всех сессий.
select date_trunc ('month',start_session) as month_session
		, count(*)
		, sum(case when end_session - start_session > interval '5 minute' then 1.0 else 0.0 end) as cnt_ss_more_than_5min
		, sum(case when end_session - start_session > interval '5 minute' then 1.0 else 0.0 end) / count(*) as part_of_all
from skygame.game_sessions
group by month_session
order by month_session
-- В дальнейшем анализе отсеем все сессии меньше 5 минут.

